# =============================================================
# Egbon AI — Environment Variables
# =============================================================

# -------------------------------------------------------------
# LLM Configuration — OpenRouter (free models)
# -------------------------------------------------------------
# Get your API key: https://openrouter.ai/keys
# Free models: google/gemma-2-9b-it:free, mistralai/mistral-7b-instruct:free,
#              meta-llama/llama-3.1-8b-instruct:free, qwen/qwen2-7b-instruct:free

OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_API_URL=https://openrouter.ai/api/v1
MODEL_NAME=mistralai/mistral-7b-instruct:free

# -------------------------------------------------------------
# Agent Server Configuration
# -------------------------------------------------------------
SERVER_PORT=3000

# -------------------------------------------------------------
# User Preferences
# -------------------------------------------------------------
MIN_BOUNTY_VALUE=100
RATE_ALERT_THRESHOLD=1500
DEFAULT_LANGUAGE=pidgin

# -------------------------------------------------------------
# Optional: Social Integrations
# -------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# DISCORD_API_TOKEN=
